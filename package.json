{
    "name": "spark-template",
    "private": true,
    "version": "8.0.0",
    "type": "module",
    "engines": {
        "node": ">=24.0.0"
    },
    "scripts": {
        "dev": "vite",
        "kill": "fuser -k 5000/tcp",
        "build": "tsc -b && vite build",
        "build:dev": "tsc -b && vite build --mode development",
        "lint": "eslint .",
        "lint:fix": "eslint . --fix",
        "typecheck": "tsc -p tsconfig.json --noEmit",
        "check:deps": "npx --yes knip",
        "optimize": "vite optimize",
        "preview": "vite preview",
        "test": "vitest",
        "test:ui": "vitest --ui",
        "test:coverage": "vitest run --coverage",
        "test:coverage:check": "vitest run --coverage",
        "android:add": "npx cap add android",
        "android:sync": "npm run build && npx cap sync android",
        "android:open": "npx cap open android",
        "android:build": "npm run build:dev && npx cap sync android && cd android && ./gradlew assemblePlayDebug",
        "android:build:release": "npm run build && npx cap sync android && cd android && ./gradlew assemblePlayRelease",
        "android:build:fdroid": "npm run build && npx cap sync android && cd android && ./gradlew assembleFdroidRelease",
        "android:bundle:play": "npm run build && npx cap sync android && cd android && ./gradlew bundlePlayRelease",
        "android:run": "npm run android:sync && npx cap run android",
        "e2e:android": "maestro test .maestro/"
    },
    "dependencies": {
        "@ai-sdk/anthropic": "^3.0.74",
        "@ai-sdk/google": "^3.0.67",
