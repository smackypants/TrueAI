; Required because @github/spark up to 0.46.2 still declares its peer
; `vite` as `^7.0.0 || ^6.4.1`, but the project ships Vite 8 (PR #149).
; npm 11's strict peer enforcement fails `npm ci`/`npm install` without
; this opt-in. Drop this file once @github/spark publishes a release that
; includes Vite 8 in its peer range.
legacy-peer-deps=true
