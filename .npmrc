; @github/spark@0.46.x declares peer vite "^7.0.0 || ^6.4.1" but works
; fine with vite 8 (which the root project pins via package.json). Until
; a spark release relaxes that peer dep, npm ci must accept the mismatch
; instead of failing with ERESOLVE. The lockfile is still authoritative
; — overrides pins in package.json are unaffected.
legacy-peer-deps=true
